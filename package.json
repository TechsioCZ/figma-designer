{
  "name": "figma-designer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Codex Figma Skills Template for strict New Engine Design System composition.",
  "scripts": {
    "figma": "node scripts/figma-designer.mjs",
    "figma:bootstrap": "node scripts/figma-designer.mjs bootstrap",
    "figma:discover": "node scripts/figma-designer.mjs discover",
    "figma:nesting": "node scripts/figma-designer.mjs nesting",
    "figma:validate": "node scripts/figma-designer.mjs validate",
    "figma:report": "node scripts/figma-designer.mjs report",
    "figma:iterate": "node scripts/figma-designer.mjs iterate",
    "figma:validate-schemas": "node scripts/figma-designer.mjs validate-schemas",
    "figma:update-env": "node scripts/update-figma-env.mjs",
    "figma:doctor": "node scripts/figma-doctor.mjs",
    "setup:figma-codex": "node scripts/setup-figma-codex.mjs",
    "setup:local": "npm run setup:figma-codex && npm run figma:doctor",
    "test": "node --test tests/*.test.mjs",
    "validate:schemas": "node scripts/figma-designer.mjs validate-schemas"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "apca-w3": "0.1.9"
  }
}
