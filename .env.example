# Copy this file to .env and fill in your live Figma values.
# .env is ignored by git because it contains secrets.

FIGMA_ACCESS_TOKEN=
FIGMA_FILE_KEY=
FIGMA_FILE_URL=

# Optional. Defaults are usually enough.
FIGMA_GENERATION_PAGE="Generation Workspace"
FIGMA_LIBRARY_NAME=

# Optional. Makes MCP first-run creation fully non-interactive when your Figma
# account belongs to multiple plans or you want a specific project.
FIGMA_PLAN_KEY=
FIGMA_PROJECT_ID=

# Advanced opt-outs only. Live bootstrap assumes these are true unless set to false.
# FIGMA_LIBRARY_CONNECTED_ASSETS=false
# FIGMA_CAN_WRITE=false
# FIGMA_CAN_SCREENSHOT=false

# Advanced screenshot override only. Figma URLs use node-id=2-2; this CLI expects 2:2.
# FIGMA_BOOTSTRAP_NODE_ID=2:2
