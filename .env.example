# Copy this file to .env and fill in your live Figma values.
# .env is ignored by git because it contains secrets.

FIGMA_ACCESS_TOKEN=
FIGMA_FILE_KEY=
FIGMA_GENERATION_PAGE="Generation Workspace"
FIGMA_LIBRARY_NAME=
FIGMA_LIBRARY_CONNECTED_ASSETS=true
FIGMA_CAN_WRITE=true
FIGMA_CAN_SCREENSHOT=true

# Node id for the bootstrap screenshot probe.
# Figma URLs use node-id=2-2, but this CLI expects 2:2.
FIGMA_BOOTSTRAP_NODE_ID=2:2
